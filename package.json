{
	"name": "n8n-nodes-timizer",
	"version": "0.1.1",
	"description": "n8n community node for Timizer - Timesheet management platform",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"timizer",
		"timesheet",
		"activity-report"
	],
	"license": "MIT",
	"homepage": "https://github.com/timizerio/timizer-n8n-node",
	"author": {
		"name": "Timizer",
		"email": "thibault@timizer.io"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/timizerio/timizer-n8n-node.git"
	},
	"scripts": {
		"build": "tsc && gulp build:icons",
		"dev": "tsc --watch",
		"format": "prettier nodes credentials --write",
		"lint": "eslint nodes credentials --ext .ts",
		"lintfix": "eslint nodes credentials --ext .ts --fix",
		"prepublishOnly": "npm run build"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/TimizerApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Timizer/Timizer.node.js",
			"dist/nodes/TimizerTrigger/TimizerTrigger.node.js"
		]
	},
	"devDependencies": {
		"@types/node": "^25.3.0",
		"@typescript-eslint/eslint-plugin": "^7.0.0",
		"@typescript-eslint/parser": "^7.0.0",
		"eslint": "^8.56.0",
		"eslint-plugin-n8n-nodes-base": "^1.16.0",
		"gulp": "^4.0.2",
		"n8n-workflow": "^1.0.0",
		"prettier": "^3.2.0",
		"typescript": "^5.3.0"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"engines": {
		"node": ">=18.0.0"
	}
}
